{
  "private": true,
  "name": "website",
  "author": {
    "name": "Tomer Aberbach",
    "email": "tomeraberbach@gmail.com",
    "url": "https://tomeraberba.ch"
  },
  "scripts": {
    "lint:prettier:base": "prettier --loglevel silent",
    "lint:prettier": "pnpm run lint:prettier:base -- --write .",
    "lint:eslint:base": "eslint --cache --ext js --ignore-path .gitignore --ignore-pattern \"**/fixtures/**/*\"",
    "lint:eslint": "pnpm run lint:eslint:base -- --fix .",
    "lint": "run-s lint:*",
    "test": "ava",
    "build": "babel-node src/index.js",
    "clean": "rimraf build"
  },
  "eslintConfig": {
    "extends": "@tomer",
    "rules": {
      "react/react-in-jsx-scope": "off",
      "react/prop-types": "off"
    }
  },
  "prettier": "@tomer/prettier-config",
  "browserslist": [
    "current node"
  ],
  "babel": {
    "presets": [
      "@babel/env",
      "power-assert"
    ],
    "plugins": [
      [
        "transform-react-jsx",
        {
          "pragma": "html",
          "pragmaFrag": "html",
          "useSpread": true
        }
      ],
      [
        "jsx-pragmatic",
        {
          "module": "html",
          "import": "html"
        }
      ],
      [
        "module-resolver",
        {
          "root": [
            "./src"
          ]
        }
      ]
    ]
  },
  "lint-staged": {
    "*.js": [
      "pnpm run lint:eslint:base -- --fix",
      "pnpm run lint:prettier:base -- --write"
    ],
    "!(pnpm-lock).{json,yaml,md}": "pnpm run lint:prettier:base -- --write"
  },
  "commitlint": {
    "extends": "@commitlint/config-conventional"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "ava": {
    "babel": true,
    "require": [
      "@babel/register"
    ],
    "files": [
      "**/{*.,}test.js"
    ]
  },
  "dependencies": {
    "html-tags": "3.1.0"
  },
  "devDependencies": {
    "@ava/babel": "1.0.1",
    "@babel/core": "7.11.6",
    "@babel/node": "7.10.5",
    "@babel/preset-env": "7.11.5",
    "@babel/register": "7.11.5",
    "@commitlint/cli": "9.1.2",
    "@commitlint/config-conventional": "9.1.2",
    "@tomer/eslint-config": "0.0.7",
    "@tomer/prettier-config": "0.0.2",
    "ava": "3.12.1",
    "ava-fast-check": "3.0.0",
    "babel-eslint": "10.1.0",
    "babel-plugin-jsx-pragmatic": "1.0.2",
    "babel-plugin-module-resolver": "4.0.0",
    "babel-plugin-transform-react-jsx": "6.24.1",
    "babel-preset-power-assert": "3.0.0",
    "eslint": "7.9.0",
    "fast-check": "2.3.0",
    "husky": "4.3.0",
    "lint-staged": "10.3.0",
    "npm-run-all": "4.1.5",
    "power-assert": "1.6.1",
    "prettier": "2.1.1",
    "rimraf": "3.0.2"
  }
}
