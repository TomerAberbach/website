---
import { formatDatesForDisplay, formatMinutesToRead } from '~/lib/format.ts'
import type { SeoProps } from '~/lib/meta.ts'
import { SITE_KEYWORDS, SITE_TITLE_AND_AUTHOR } from '~/lib/meta.ts'
import { getSiteUrl } from '~/lib/site-url.ts'
import { THUMBNAIL_HEIGHT, THUMBNAIL_WIDTH } from '~/lib/thumbnail-constants.ts'

type Props = SeoProps

const { title, description, keywords = new Set(), post, type } = Astro.props

const canonicalUrl = getSiteUrl(Astro.url.pathname)
const allKeywords = [...new Set([...SITE_KEYWORDS, ...keywords])].join(`, `)

const image = post
  ? {
      url: getSiteUrl(`${post.id}.png`),
      alt: `${post.title}. ${formatDatesForDisplay(post.dates)}. ${formatMinutesToRead(
        post.minutesToRead,
      )}. By ${SITE_TITLE_AND_AUTHOR}.`,
    }
  : null
---

<title>{title}</title>
<link rel="canonical" href={canonicalUrl} />
<meta name="description" content={description} />
<meta name="keywords" content={allKeywords} />
<meta name="author" content={SITE_TITLE_AND_AUTHOR} />

{
  post && image && (
    <Fragment>
      {/* https://ogp.me */}
      <meta property="og:title" content={title} />
      <meta property="og:description" content={description} />
      <meta property="og:url" content={canonicalUrl} />

      <meta property="og:image" content={image.url} />
      <meta property="og:image:type" content="image/png" />
      <meta property="og:image:width" content={String(THUMBNAIL_WIDTH)} />
      <meta property="og:image:height" content={String(THUMBNAIL_HEIGHT)} />
      <meta property="og:image:alt" content={image.alt} />

      <meta property="og:type" content={type} />
      {type === `article` && (
        <Fragment>
          <meta
            property="article:published_time"
            content={post.dates.published.toISOString()}
          />
          {post.dates.updated && (
            <meta
              property="article:modified_time"
              content={post.dates.updated.toISOString()}
            />
          )}
          <meta property="article:author" content={SITE_TITLE_AND_AUTHOR} />
          {[...post.tags].map(tag => (
            <meta property="article:tag" content={tag} />
          ))}
        </Fragment>
      )}

      {/* X */}
      <meta name="twitter:card" content="summary_large_image" />
      <meta name="twitter:site" content="@TomerAberbach" />
      <meta name="twitter:title" content={title} />
      <meta name="twitter:description" content={description} />
      <meta name="twitter:image" content={image.url} />
      <meta name="twitter:image:alt" content={image.alt} />
    </Fragment>
  )
}
